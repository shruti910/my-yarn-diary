# =========================================================================
# VITE CLIENT ENVIRONMENT CONFIGURATIONS
# =========================================================================
VITE_APP_PROFILE=production

# Your entry point API gateway address (pointing to your container router)
VITE_GATEWAY_URL=https://your-production-gateway-url.com

# Sentry Public link for tracking browser bugs and client app metrics
VITE_SENTRY_DSN=https://your-public-sentry-dsn-token-here

# =========================================================================
# FIREBASE CLIENT-SIDE PUBLIC INTEGRATION KEYS
# =========================================================================
VITE_FIREBASE_API_KEY=AIzaSyYourPublicClientApiKeyGoesHere
VITE_FIREBASE_AUTH_DOMAIN=your-app-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id-here
VITE_FIREBASE_STORAGE_BUCKET=your-app-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890