# =========================================================================
# SYSTEM ENVIRONMENT PROFILE
# =========================================================================
APP_PROFILE=dev

# =========================================================================
# SECURE IDENTITY KEYS & THIRD-PARTY SERVICES
# =========================================================================
LLM_TEXT_GENERATION_PROVIDER=gemini #gemini or openai
LLM_IMAGE_GENERATION_PROVIDER=pollinations #gemini or openai or pollinations
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
IMAGE_GENERATION_TOKEN_COST=2500
IMAGE_GENERATION_DEFAULT_WIDTH=512
IMAGE_GENERATION_DEFAULT_HEIGHT=512
IMAGE_GENERATION_DEFAULT_MODEL=your_image_model

FIREBASE_PROJECT_ID=your_firebase_project_for_authentication_here
INTERNAL_JWT_SECRET=your_super_secure_jwt_secret_here

# =========================================================================
# ONE SHARED POSTGRESQL DATABASE AND USER; FLYWAY OWNS SERVICE SCHEMAS
# =========================================================================
CROCHET_DB_NAME=crochet_db
CROCHET_DB_USER=crochet_admin
CROCHET_DB_PASSWORD=your_super_secure_crochet_db_password_here

DB_ENCRYPTION_SECRET=your_super_secure_db_encryption_secret_here

# =========================================================================
# API GATEWAY & MICROSERVICE PORT BINDINGS (HOST NETWORK MAPS)
# =========================================================================
GATEWAY_PORT=3000

# =========================================================================
# GRAFANA CLOUD
# =========================================================================
GRAFANA_USER_ID=your_grafana_instance_id
GRAFANA_API_TOKEN=your_grafana_cloud_access_policy_token
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-your-region.grafana.net/otlp
GRAFANA_HOST_NAME=your_host_name

# Microservices route telemetry to the local collector
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf


# =========================================================================
# DOMAIN FOR SSL/HTTPS (e.g. yourdomain.com or IP.sslip.io)
# =========================================================================
DOMAIN=localhost

# Path to Firebase Admin SDK Credentials file
FIREBASE_CREDENTIALS_PATH=./secrets/firebase-credentials-dev.json
